# Komodos Provision — every switch is OFF by default. The app runs fully without this file.
# Copy to .env and set only what you want to graduate.

# ── core ─────────────────────────────────────────────────────────────────────
PORT=8788
# Pin this so sessions survive a restart. Leave unset in demo and tokens rotate on boot.
AUTH_SECRET=
# Dev only — the SPA origin allowed to call the API. Same-origin production needs nothing.
CORS_ORIGIN=http://localhost:5173
# Password for the seeded demo directory.
DEMO_PASSWORD=mise
# Set to `off` for an ephemeral in-memory store (no server/.data writes).
PERSIST=
# Change to regenerate the whole simulated venue with a different (still stable) shape.
SIM_SEED=20260718

# ── supplier dispatch ────────────────────────────────────────────────────────
# UNSET = demo: a PO is recorded but never sent anywhere (channel = 'logged').
# SET   = the approved PO is actually emailed to the distributor.
SUPPLIER_ORDER_EMAIL=

# ── Anthropic — a real model call for the co-pilot ───────────────────────────
# UNSET = the co-pilot answers from the deterministic grounded responder (still useful, and
# still reads the live records — it just isn't a model).
# SET   = the co-pilot calls Claude over a snapshot of the live records. The snapshot is the
#         only source of truth in the prompt, so answers stay grounded in real numbers.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── InsForge — data plane (Postgres, Auth, Storage, Model Gateway) ───────────
# Setting both flips records/auth/storage/llm from 'local' to 'insforge' in /api/health.
INSFORGE_URL=
INSFORGE_KEY=
INSFORGE_MODEL=claude-sonnet-4-6

# ── Runtype — agent & flow runtime (over MCP) ────────────────────────────────
# Setting this routes the co-pilot, reorder decisioner, invoice reconciler and guest
# predictor to real agents instead of the local heuristics.
RUNTYPE_TOKEN=

# ── Cotal — multi-agent coordination mesh (NATS/JetStream) ───────────────────
# Only meaningful once more than one agent is live.
COTAL_URL=
COTAL_JWT=
